# SUPABASE
SUPABASE_URL=
SUPABASE_ANON_KEY=

# CLOUDFLARE R2 binding is configured in Pages, not as text secret:
# CATALOGUE_BUCKET

# KIM FEATURE FLAGS
KIM_ENABLED=true
KIM_VECTOR_SEARCH_ENABLED=false
KIM_GEMINI_RERANK_ENABLED=false
KIM_GEMMA_JUDGE_ENABLED=false
KIM_V4_ROLLBACK_ENABLED=true

# VECTOR PROFILE
KIM_VECTOR_MODEL=dinov2_vits14
KIM_VECTOR_MODEL_VERSION=1
KIM_PREPROCESS_VERSION=kim_fg_v1
KIM_EMBEDDING_PROFILE=cls_l2_v1
KIM_VECTOR_DIMENSION=384
KIM_VECTOR_TOP_K=30
KIM_RESOLVER_TOP_K=10
KIM_VECTOR_MIN=0.55
KIM_MAX_SCAN_ROWS=1500

# EXTERNAL SPECIALIZED MODEL ENDPOINTS
# One of these is required if the client does not send query_embedding.
KIM_EMBEDDING_ENDPOINT=
KIM_EMBEDDING_BEARER_TOKEN=

# Optional dedicated background-removal / segmentation endpoint.
KIM_FOREGROUND_ENDPOINT=
KIM_FOREGROUND_BEARER_TOKEN=

# GEMINI
GEMINI_API_KEY=
KIM_GEMINI_MODEL=gemini-3.5-flash
KIM_GEMINI_RERANK_ENABLED=false
KIM_MAX_GEMINI_CALLS=1
KIM_GEMINI_TIMEOUT_MS=60000

# OPENROUTER / GEMMA
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Thu Ky Kim
KIM_GEMMA_MODEL=google/gemma-4-31b-it:free
KIM_GEMMA_JUDGE_ENABLED=false
KIM_MAX_OPENROUTER_CALLS=1
KIM_OPENROUTER_TIMEOUT_MS=30000

# GATES
KIM_AMBIGUITY_GAP=0.035
KIM_JUDGE_GAP=0.05

# ADMIN ROUTES
KIM_ADMIN_TOKEN=
