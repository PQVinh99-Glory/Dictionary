# Cloudflare Pages Variables / Secrets

# Secret
OPENROUTER_API_KEY=sk-or-v1-...

# Existing Supabase project
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Optional model overrides
DENIS_MODEL_PLANNER=google/gemma-4-26b-a4b-it:free
DENIS_MODEL_VISION=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
DENIS_MODEL_JUDGE=google/gemma-4-31b-it:free

DENIS_JUDGE_ENABLED=true
DENIS_MAX_CANDIDATES=12
DENIS_VERIFY_TOP_K=4
DENIS_MAX_SCAN_ROWS=1500

OPENROUTER_APP_NAME=Denis Catalogue AI
OPENROUTER_HTTP_REFERER=https://dictionary-dnw.pages.dev
