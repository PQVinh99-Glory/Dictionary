SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Primary multimodal provider
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
DENIS_GEMINI_MODEL=gemini-3.1-pro-preview

# Critic / metadata resolver / visual fallback
OPENROUTER_API_KEY=sk-or-v1-...
DENIS_GEMMA_MODEL=google/gemma-4-31b-it:free

# Hard budgets
DENIS_MAX_AI_CALLS_PER_QUERY=3
DENIS_MAX_GEMINI_CALLS_PER_QUERY=2
DENIS_MAX_OPENROUTER_CALLS_PER_QUERY=1

# Candidate limits
DENIS_MAX_CANDIDATE_IMAGES=10
DENIS_MAX_CANDIDATE_POOL=24
DENIS_MAX_SCAN_ROWS=1500

# Timeouts
DENIS_GEMINI_TIMEOUT_MS=60000
DENIS_OPENROUTER_TIMEOUT_MS=30000

# Ambiguity
DENIS_AMBIGUITY_GAP=0.08
